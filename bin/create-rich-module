#!/usr/bin/env php
<?php

if (!isset($argv[1])) {
    error(sprintf('Usage: %s <module-name> [<src-directory>]', basename($argv[0])));
}

$module = ucfirst((string) $argv[1]);

// Determine repository root directory
if (isset($GLOBALS['_composer_bin_dir'])) {
    assert(isset($_composer_bin_dir));

    $rootDir = dirname(dirname($_composer_bin_dir));
} else {
    $rootDir = getcwd();
}

// Determine source directory
$srcDir = $rootDir.'/'.($argv[2] ?? 'src');

if (!is_dir($srcDir)) {
    error(sprintf('Source directory "%s" not found.', $srcDir));
}

$srcDir = $srcDir.'/Module/'.$module;

$directories = [
    $srcDir.'/Action/Command',
    $srcDir.'/Action/Event',
    $srcDir.'/Action/Handler/Exception',
    $srcDir.'/Action/Input',
    $srcDir.'/Contract/Enum',
    $srcDir.'/Contract/Exception',
    $srcDir.'/Contract/Repository',
    $srcDir.'/Framework/Command',
    $srcDir.'/Framework/Controller',
    $srcDir.'/Framework/Controller/API',
    $srcDir.'/Framework/Controller/Web',
    $srcDir.'/Exception',
];

foreach ($directories as $directory) {
    if (!mkdir($directory, 0755, true)) {
        error(sprintf('Creating the directory "%s" failed.', $directory));
    }
}

$files = [
    "{$srcDir}/Contract/Exception/ExceptionInterface.php" => "<?php\n\nnamespace App\\Module\\{$module}\\Contract\\Exception;\n\ninterface ExceptionInterface extends \\Throwable\n{\n}",
    "{$srcDir}/Contract/Repository/{$module}RepositoryInterface.php" => "<?php\n\nnamespace App\\Module\\{$module}\\Contract\\Repository;\n\ninterface {$module}RepositoryInterface\n{\n}",
    "{$srcDir}/Exception/InvalidArgumentException.php" => "<?php\n\nnamespace App\\Module\\{$module}\\Exception;\n\nuse App\\Module\\{$module}\\Contract\\Exception\\ExceptionInterface;\n\nclass InvalidArgumentException extends \\InvalidArgumentException implements ExceptionInterface\n{\n}",
    "{$srcDir}/Exception/RuntimeException.php" => "<?php\n\nnamespace App\\Module\\{$module}\\Exception;\n\nuse App\\Module\\{$module}\\Contract\\Exception\\ExceptionInterface;\n\nclass RuntimeException extends \\RuntimeException implements ExceptionInterface\n{\n}",
];

foreach ($files as $file => $contents) {
    if (!is_file($file) && is_dir(dirname($file))) {
        /** @var non-empty-string $contents */
        $contents = sprintf("%s\n", trim($contents));

        if (false === file_put_contents($file, $contents)) {
            error(sprintf('Creating the file "%s" failed.', $file));
        }
    }
}

function error(string $message): never
{
    fwrite(STDERR, sprintf("[ERROR] %s\n", trim($message)));
    exit(1);
}
