{
    "name": "1tomany/rich-bundle",
    "description": "Symfony bundle that provides easy scaffolding to build RICH applications",
    "license": "MIT",
    "type": "symfony-bundle",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "symfony/config": "^7.2|^8.0",
        "symfony/dependency-injection": "^7.2|^8.0",
        "symfony/event-dispatcher": "^7.2|^8.0",
        "symfony/form": "^7.2|^8.0",
        "symfony/http-foundation": "^7.2|^8.0",
        "symfony/http-kernel": "^7.2|^8.0",
        "symfony/security-core": "^7.2|^8.0",
        "symfony/serializer": "^7.2|^8.0",
        "symfony/validator": "^7.2|^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpdocumentor/reflection-docblock": "^5.2",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "suggest": {
        "1tomany/data-uri-bundle": "Provides a decoder to convert data into a self-destroying file object",
        "symfony/security-bundle": "Provides an autowired TokenStorageInterface to extract authenticated users"
    },
    "autoload": {
        "psr-4": {
            "OneToMany\\RichBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OneToMany\\RichBundle\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/rich"
    ],
    "scripts": {
        "fix": "php-cs-fixer fix @additional_args",
        "stan": "phpstan @additional_args",
        "test": "phpunit @additional_args"
    },
    "authors": [
        {
            "name": "Vic Cherubini",
            "email": "vcherubini@gmail.com"
        }
    ],
    "config": {
        "sort-packages": true
    }
}
